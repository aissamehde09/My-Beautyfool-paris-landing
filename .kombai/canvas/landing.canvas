      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Montserrat:wght@100..900&family=Dancing+Script:wght@400..700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-sans { font-family: 'Montserrat', sans-serif; }\n  .font-script { font-family: 'Dancing Script', cursive; }\n\n  .double-border::before {\n    content: '';\n    position: absolute;\n    inset: 8px;\n    border: 1px solid #D4AF37;\n    pointer-events: none;\n    border-radius: inherit;\n  }\n\n  .arch-mask {\n    border-radius: 1000px 1000px 0 0;\n  }\n</style>\n\n<div class=\"min-h-[1200px] bg-[#FAFAFA] font-sans text-[#031f46] relative overflow-hidden flex flex-col items-center\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute -left-32 -top-20 w-[450px] h-[700px] arch-mask border border-[#D4AF37]/30 opacity-10 -z-10 overflow-hidden\" data-kid=\"2\">\n    <img src=\"https://images.unsplash.com/photo-1577354425215-479a15121ed8?auto=format&w=800&q=80\" alt class=\"w-full h-full object-cover blur-sm\" data-kid=\"3\">\n  </div>\n\n  \n  <div class=\"absolute -right-32 bottom-0 w-[450px] h-[700px] arch-mask border border-[#D4AF37]/30 opacity-10 -z-10 overflow-hidden rotate-180\" data-kid=\"4\">\n    <img src=\"https://images.unsplash.com/photo-1549717850-6eafffa4ce81?auto=format&w=800&q=80\" alt class=\"w-full h-full object-cover blur-sm\" data-kid=\"5\">\n  </div>\n\n  \n  <header class=\"w-full max-w-4xl pt-12 flex flex-col items-center gap-8\" data-kid=\"6\">\n    <img src=\"/api/local/images/public/images/logo.jpeg\" alt=\"My Beautyfool Paris\" class=\"h-20 w-auto object-contain\" data-kid=\"7\">\n    <div class=\"w-24 h-px bg-[#D4AF37]\" data-kid=\"8\"></div>\n  </header>\n\n  \n  <main class=\"w-full max-w-[800px] px-6 mt-16 flex flex-col items-center\" data-kid=\"9\">\n    \n    \n    <div class=\"w-full bg-[#031f46] text-white p-12 md:p-20 rounded-sm relative double-border shadow-2xl text-center\" data-kid=\"10\">\n      <h1 class=\"font-serif text-5xl md:text-7xl leading-tight mb-8\" data-kid=\"11\">\n        Merci <span class=\"italic\" data-kid=\"12\">infiniment</span>\n      </h1>\n      \n      <div class=\"flex items-center justify-center gap-4 text-[#D4AF37] mb-12\" data-kid=\"13\">\n        <span class=\"h-px w-12 bg-[#D4AF37]/40\" data-kid=\"14\"></span>\n        <div class=\"flex items-center justify-center w-12 h-12 rounded-full border border-[#D4AF37]\" data-kid=\"15\">\n          <i class=\"ti ti-heart-filled text-xl\" data-kid=\"16\"></i>\n        </div>\n        <span class=\"h-px w-12 bg-[#D4AF37]/40\" data-kid=\"17\"></span>\n      </div>\n\n      <div class=\"space-y-6 max-w-md mx-auto\" data-kid=\"18\">\n        <div class=\"flex items-start gap-4 text-left\" data-kid=\"19\">\n          <div class=\"w-10 h-10 rounded-full bg-[#D4AF37] flex items-center justify-center shrink-0\" data-kid=\"20\">\n            <i class=\"ti ti-gift text-[#031f46] text-xl\" data-kid=\"21\"></i>\n          </div>\n          <div data-kid=\"22\">\n            <p class=\"font-bold uppercase tracking-wider text-sm mb-1\" data-kid=\"23\">Cadeau de Bienvenue</p>\n            <p class=\"text-white/80 text-base leading-relaxed\" data-kid=\"24\">Votre accès exclusif arrive dans votre boîte mail d'ici quelques heures. Pensez à vérifier vos spams.</p>\n          </div>\n        </div>\n\n        <div class=\"flex items-start gap-4 text-left\" data-kid=\"25\">\n          <div class=\"w-10 h-10 rounded-full border border-[#D4AF37]/40 flex items-center justify-center shrink-0\" data-kid=\"26\">\n            <i class=\"ti ti-mail text-[#D4AF37] text-xl\" data-kid=\"27\"></i>\n          </div>\n          <div data-kid=\"28\">\n            <p class=\"font-bold uppercase tracking-wider text-sm mb-1\" data-kid=\"29\">Confirmation</p>\n            <p class=\"text-white/80 text-base leading-relaxed\" data-kid=\"30\">Votre inscription au Private Club est désormais confirmée.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <section class=\"mt-24 text-center max-w-2xl px-4\" data-kid=\"31\">\n      <div class=\"flex flex-col items-center gap-6\" data-kid=\"32\">\n        <div class=\"text-[#D4AF37] text-3xl\" data-kid=\"33\">\n          <i class=\"ti ti-crown\" data-kid=\"34\"></i>\n        </div>\n        <h2 class=\"font-serif text-3xl md:text-4xl text-[#031f46]\" data-kid=\"35\">Une nouvelle ère pour My Beautyfool Paris</h2>\n        <p class=\"text-slate-600 leading-relaxed text-lg italic\" data-kid=\"36\">\n          \"Grâce à votre fidélité, nous avons lancé notre nouvelle plateforme de réservation directe. Aujourd'hui, nous avons besoin de votre précieux soutien.\"\n        </p>\n        <div class=\"w-16 h-px bg-slate-200\" data-kid=\"37\"></div>\n      </div>\n    </section>\n\n    \n    <section class=\"mt-20 w-full bg-white p-10 md:p-16 rounded-sm border border-slate-100 shadow-xl flex flex-col items-center text-center\" data-kid=\"38\">\n      <div class=\"flex gap-2 text-[#D4AF37] mb-6\" data-kid=\"39\">\n        <i class=\"ti ti-star-filled text-2xl\" data-kid=\"40\"></i>\n        <i class=\"ti ti-star-filled text-2xl\" data-kid=\"41\"></i>\n        <i class=\"ti ti-star-filled text-2xl\" data-kid=\"42\"></i>\n        <i class=\"ti ti-star-filled text-2xl\" data-kid=\"43\"></i>\n        <i class=\"ti ti-star-filled text-2xl\" data-kid=\"44\"></i>\n      </div>\n      \n      <h3 class=\"font-serif text-3xl text-[#031f46] mb-4\" data-kid=\"45\">Avez-vous aimé votre séjour ?</h3>\n      <p class=\"text-slate-500 max-w-sm mb-10 leading-relaxed\" data-kid=\"46\">\n        Votre avis sur Google aide d'autres voyageurs à découvrir l'excellence de nos appartements parisiens.\n      </p>\n\n      <a href=\"#\" class=\"inline-flex items-center gap-4 bg-[#cf0616] text-white px-10 py-5 rounded-sm font-bold uppercase tracking-[0.1em] hover:bg-[#b90513] transition-all shadow-lg hover:shadow-red-900/20 group\" data-kid=\"47\">\n        <span class=\"w-8 h-8 rounded-full bg-white flex items-center justify-center text-[#4285f4] text-sm font-black\" data-kid=\"48\">G</span>\n        Laisser un avis Google\n        <i class=\"ti ti-arrow-right transition-transform group-hover:translate-x-1\" data-kid=\"49\"></i>\n      </a>\n\n      <p class=\"mt-8 font-script text-3xl text-[#cf0616]\" data-kid=\"50\">\n        Cela prend moins de 30 secondes <span class=\"text-xl\" data-kid=\"51\">♥</span>\n      </p>\n    </section>\n\n    \n    <footer class=\"mt-24 mb-20 text-center\" data-kid=\"52\">\n      <p class=\"font-script text-4xl text-[#031f46] mb-4\" data-kid=\"53\">Merci pour votre confiance,</p>\n      <p class=\"font-bold uppercase tracking-[0.2em] text-xs text-slate-400 flex items-center justify-center gap-3\" data-kid=\"54\">\n        L'équipe My Beautyfool Paris\n        <span class=\"text-[#cf0616] tracking-normal text-base\" data-kid=\"55\">♥</span>\n      </p>\n    </footer>\n\n  </main>\n</div>",
